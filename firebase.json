{
    "firestore": {
        "rules": "firestore.rules"
    },
    "storage": {
        "rules": "storage.rules"
    },
    "functions": {
        "source": "functions",
        "runtime": "nodejs24"
    },
    "hosting": {
        "public": "out",
        "cleanUrls": true,
        "trailingSlash": true,
        "ignore": ["firebase.json", "**/.*", "**/node_modules/**", "**/*.json", "./createAdmin.js"],
        "rewrites": []
    }
}
