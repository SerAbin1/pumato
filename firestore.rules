rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Auth Helpers ---
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isPartner(resId) {
      return request.auth != null && request.auth.token.restaurantId == resId;
    }

    function isAnyPartner() {
      return request.auth != null && request.auth.token.restaurantId != null;
    }

    function isDeliveryPartner() {
      return request.auth != null && request.auth.token.deliveryPartner == true;
    }

    // --- Restaurants: public read, partners update own, admins full ---
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow update: if isPartner(restaurantId) || isAdmin();
      allow create, delete: if isAdmin();
    }

    // --- Site Content: public read (order settings, banners, grocery settings) ---
    match /site_content/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Laundry Slots: public read ---
    match /laundry_slots/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Laundry Settings: public read (campus config + pricing) ---
    match /laundry_settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users don't need to read their laundry orders (handled via WhatsApp/delivery flow).
    match /laundry_orders/{document} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // --- Orders: NO public read ---
    // Admins: full access
    // Partners: read + update orders containing their restaurantId
    // Delivery partners: read ready_for_delivery orders; claim by updating to picked_up
    // Users: read own orders (by userId)
    // Public: create only
    match /orders/{orderId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAdmin();
      allow read, update: if isAnyPartner()
        && request.auth.token.restaurantId in resource.data.restaurantIds;
      allow read: if isDeliveryPartner()
        && resource.data.status in ["ready_for_delivery", "picked_up"];
      allow update: if isDeliveryPartner()
        && resource.data.status == "ready_for_delivery"
        && request.resource.data.status == "picked_up"
        && request.resource.data.deliveryPartnerUid == request.auth.uid;
      allow update: if isDeliveryPartner()
        && resource.data.status == "picked_up"
        && request.resource.data.status == "delivered"
        && resource.data.deliveryPartnerUid == request.auth.uid;
    }

    // --- FCM Tokens: own user only ---
    match /fcm_tokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Marketplace Requests: public create (seller's sell request), admin-only inbox ---
    match /marketplace_requests/{document} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // --- Marketplace Listings: public read, admin-authored ---
    match /marketplace_listings/{document} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- Catch-all: admin write only, no public read for unlisted collections ---
    match /{document=**} {
      allow write, read: if isAdmin();
    }
  }
}
