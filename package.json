{
  "name": "pumato",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.test -- next dev",
    "dev:prod": "dotenv -e .env.production -- next dev",
    "build": "dotenv -e .env.production next build",
    "lint": "eslint . --cache",
    "lintfix": "eslint . --cache --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "deploy": "dotenv -e .env.production pnpm run build && firebase deploy",
    "test": "dotenv -e .env.test -- playwright test",
    "test:ui": "dotenv -e .env.test -- playwright test --ui",
    "test:debug": "dotenv -e .env.test -- playwright test --debug",
    "test:create": "dotenv -e .env.test -- playwright codegen http://localhost:3000"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@supabase/supabase-js": "^2.91.1",
    "clsx": "^2.1.1",
    "firebase": "^12.8.0",
    "firebase-admin": "^13.6.0",
    "framer-motion": "^12.26.1",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": ["eslint --fix", "prettier --write"]
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
