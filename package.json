{
    "name": "pumato",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "dotenv -e .env.test -- next dev",
        "dev:prod": "dotenv -e .env.production -- next dev",
        "build": "dotenv -e .env.production next build",
        "lint": "eslint .",
        "lintfix": "eslint . --fix",
        "format": "prettier --write .",
        "prepare": "husky",
        "deploy": "dotenv -e .env.production pnpm run build && firebase deploy",
        "deploy:rules": "firebase deploy --only firestore:rules,storage",
        "test": "dotenv -e .env.test -- playwright test",
        "test:ui": "dotenv -e .env.test -- playwright test --ui",
        "test:debug": "dotenv -e .env.test -- playwright test --debug",
        "test:create": "dotenv -e .env.test -- playwright codegen http://localhost:3000",
        "test:unit": "vitest run"
    },
    "dependencies": {
        "@opentelemetry/api": "^1.9.0",
        "clsx": "^2.1.1",
        "firebase": "^12.8.0",
        "firebase-admin": "^13.6.0",
        "framer-motion": "^12.26.1",
        "fuse.js": "^7.1.0",
        "lucide-react": "^0.562.0",
        "next": "16.1.1",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-hot-toast": "^2.6.0",
        "recharts": "^3.8.0",
        "tailwind-merge": "^3.4.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tailwindcss/postcss": "^4",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9",
        "eslint-config-next": "16.1.1",
        "husky": "^9.0.0",
        "lint-staged": "^15.0.0",
        "prettier": "^3.0.0",
        "tailwindcss": "^4",
        "vitest": "^4.1.9"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ]
    },
    "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}
